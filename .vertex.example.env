# Optional: use a different GCP project to host Vertex AI than the project
# where you run GKE, LiteLLM, and Entra-related setup.
VERTEX_PROJECT_ID=your-vertex-provider-project-id
VERTEX_LOCATION=us-central1

# Optional and recommended for cross-team ownership: let the remote Vertex team
# manage API enablement and IAM in their own project.
VERTEX_SKIP_PROJECT_SETUP=true

# Optional fallback when Workload Identity cannot be granted across projects or orgs.
# Prefer the file form over pasting JSON inline.
# VERTEXAI_CREDENTIALS_FILE=.secrets/vertex-provider-service-account.json
# VERTEXAI_CREDENTIALS={"type":"service_account","project_id":"your-vertex-provider-project-id"}
